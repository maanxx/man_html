package users

import (
	"app/pkg/golangviet/templates"
	"app/views/layouts"
)

templ Index() {
	@layouts.Master(&[]templ.Component{head()}, scriptSlot()) {
		<div class="row">
			<div class="col-12">
				<div class="page-title-box d-sm-flex align-items-center justify-content-between">
					<h4 data-key="t-admin">Admin</h4>
					<div class="page-title-right">
						<ol class="breadcrumb m-0">
							<li class="breadcrumb-item"><a href="javascript: void(0);" data-key="t-users">Users</a></li>
							<li class="breadcrumb-item active" data-key="t-list">List</li>
						</ol>
					</div>
				</div>
			</div>
		</div>
		<div class="row">
			<div class="col-xxl-9">
				<div class="col-lg-12">
					<div class="card" id="orderList">
						<div class="w-100 card-body border-end-0 border-start-0 d-lg-flex align-items-center justify-content-between">
							<div class="row align-items-center gy-3 w-100">
								<div class="col-sm">
									<h5 class="card-title mb-0" data-key="t-user-list">User list</h5>
								</div>
								<div class="col-sm-auto d-lg-flex gap-2 align-items-center justify-content-center">
									<button
										class="btn btn-danger"
										id="remove-actions"
										data-url={ templates.AssetURL("/api/admins/users/delete") }
										data-bs-toggle="modal"
										data-bs-target="#delete_modal"
									>
										<i class="ri-delete-bin-2-line"></i>
									</button>
									<button
										type="button"
										class="btn btn-secondary add-btn"
										data-bs-toggle="modal"
										data-bs-target="#create_user_modal"
										id="create-btn"
									>
										<i class="mdi mdi-plus"></i><span
	data-key="t-add-user"
>Add User</span>
									</button>
								</div>
							</div>
						</div>
						<div class="card-body pt-2">
							<div>
								<div class="table-responsive table-card mb-1">
									<table class="table table-hover align-middle m-0" id="user_table" data-domain={templates.AssetURL("")}
										style="min-height: 200px;width:100%">
										<thead class="table-light text-muted">
											<tr class="text-uppercase">
												<th style="width: 20px;">
													<div class="form-check">
														<input class="form-check-input" type="checkbox" id="checkAll" value="option">
													</div>
												</th>
												<th data-key="t-action">Action</th>
												<th class="text-left">NO.</th>
												<th>Avatar</th>
												<th data-key="t-fullname">Full name</th>    
												<th data-key="t-role">Role</th>                                                                            
												<th data-key="t-status">Status</th>
												<th data-key="t-audit-info">Audit Info</th>
											</tr>
										</thead>
									</table>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			// @components.InfoUserRight()
		</div>
	}
}

templ head() {
	<link rel="stylesheet" href={ templates.AssetURL("/static/themes/libs/datatables/datatables.min.css") }/>
}

templ scriptSlot() {
	<script type="text/javascript" src={ templates.AssetURL("/static/themes/libs/datatables/datatables.min.js") } defer></script>
	<script type="module" src={ templates.AssetURL("/static/js/admins/users/list.js") }></script>
	// <script type="module" src={templates.AssetURL("/static/js/admins/users/list.js")}></script>
	// <script type="module" src={templates.AssetURL("/static/js/admins/users/create.js")}></script>
}
