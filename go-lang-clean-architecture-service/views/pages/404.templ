package pages

import "app/views/layouts"

templ NotFound404(urlBack string) {
	@layouts.Master(&[]templ.Component{}, emptyComponent()) {
		<div class="row justify-content-center mt-5">
			<div class="col-md-8 col-lg-6 col-xl-5">
				<div class="card mt-4">
					<div class="card-body p-4 text-center">
						<div class="avatar-lg mx-auto mt-2">
							<div class="avatar-title bg-light text-danger display-1 rounded-circle">
								<i class="bx bx-error-circle"></i>
							</div>
						</div>
						<div class="mt-4 pt-2">
							<h4>Oops! Lỗi 404 Not Found</h4>
							<p class="text-muted mx-4">Dữ liệu sếp đang tìm kiếm không tồn tại, sai đường dẫn, hoặc đã bị xóa khỏi hệ thống.</p>
							<div class="mt-4">
								<a href={ templ.URL(urlBack) } class="btn btn-danger w-100"><i class="bx bx-arrow-back me-1"></i> Quay lại trang danh sách người dùng</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
}

templ emptyComponent() {
}
